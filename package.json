{
  "name": "keepthemoment",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "lint": "oxlint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "seed:payload": "tsx --env-file=.env scripts/seed-payload.ts",
    "seed:payload:dry-run": "tsx --env-file=.env scripts/seed-payload.ts --dry-run",
    "verify:cms": "tsx --env-file=.env scripts/verify-cms.ts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.86.0",
    "@payloadcms/next": "^3.86.0",
    "@payloadcms/richtext-lexical": "^3.86.0",
    "@payloadcms/storage-vercel-blob": "^3.86.0",
    "@payloadcms/ui": "^3.86.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "graphql": "^16.11.0",
    "next": "^15.4.11",
    "payload": "^3.86.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.4.11",
    "oxlint": "^1.71.0",
    "sass": "^1.101.6",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
