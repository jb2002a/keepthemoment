DATABASE_URI=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
PAYLOAD_SECRET=replace-with-a-long-random-string
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Required for durable media uploads on Vercel (Payload media -> Vercel Blob)
BLOB_READ_WRITE_TOKEN=

# Optional public Blob CDN base (defaults to the project store URL)
# BLOB_PUBLIC_BASE_URL=https://xxxx.public.blob.vercel-storage.com

# Optional seed admin user
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=change-me
